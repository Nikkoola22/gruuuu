# Copiez ce fichier en .env.local puis renseignez les valeurs.
# PowerShell : Copy-Item .env.local.example .env.local

# Clé API Perplexity (format attendu : pplx-...)
PERPLEXITY_API_KEY=

# Optionnel sur certains environnements Windows (problème de certificats TLS)
# Vous pouvez aussi la définir temporairement dans le terminal avant npm run dev :
# $env:NODE_OPTIONS='--use-system-ca'
NODE_OPTIONS=--use-system-ca
